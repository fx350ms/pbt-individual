@using Pbt.Individual.ApplicationUtils

@model pbt.Web.Models.Orders.OrderDetailModel
@{
    ViewBag.Title = L("OrderDetail");
}

@section styles {
    <link href="~/libs/bootstrap-steps/bootstrap-steps.css" rel="stylesheet" />

    <link rel="stylesheet" href="https://unpkg.com/bs-brain@2.0.4/tutorials/timelines/timeline-8/assets/css/timeline-8.css">
    <style>
        .bsb-timeline-8 {
            --bsb-tl-circle-border-color: #28a745;
            --bsb-tl-circle-color: #28a745;
        }

        tr.active td {
            background-color: #4ee0ff;
        }

        .dropdown-menu.show {
            left: -100px !important;
        }
    </style>
}

 
@if (Model != null && Model.Dto != null)
{
    <section class="content-header">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <!-- Tiêu đề đơn hàng -->
                    <h1 class="text-center">Chi tiết vận đơn: <strong class="text-danger"> #@Model.Dto.WaybillNumber
                    </strong></h1>
                </div>
            </div>
        </div>
    </section>

    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <!-- Timeline đơn hàng -->

                            <div class="row">
                                <!-- Timeline theo chiều ngang -->
                                <div class="col-8 offset-1">
                                    
                                </div>
                            </div>
                        </div>
                        <div class="card-body" style="padding-bottom: 0px;">
                            <div class="row">
                                <table class="table table-striped table-bordered ">
                                    <thead>
                                        <tr class="info">
                                            <th>STT</th>
                                            <th>@L("PackageCode")</th>
                                            <th>@L("TrackingNumber")</th>
                                            <th>@L("Status")</th>
                                            <th>@L("Weight")</th>
                                            <th>@L("Volume")</th>
                                            <th>@L("ShippingCost")</th>
                                            <th>@L("PackingFee")</th>
                                            <th>@L("ShockproofFee")</th>
                                            <th>@L("DomesticShippingFee")</th>
                                            <th>@L("Insurance")</th>
                                            <th>@L("TotalCost")</th>
                                            <th>@L("TimeLine")</th>
                                           
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.Packages != null && Model.Packages.Count > 0)
                                        {
                                            var _index = 0;
                                            foreach (var item in Model.Packages)
                                            {
                                                _index++;
                                                <tr>
                                                    <td class="text-center">
                                                        @_index
                                                    </td>
                                                    <td>
                                                        @item.PackageNumber
                                                    </td>
                                                    <td>
                                                        @item.TrackingNumber
                                                    </td>
                                                    
                                                    <td>
                                                        @((PackageStatus) item.Status).GetDescription())
                                                    </td>
                                                    <td>
                                                        @item.Weight
                                                    </td>
                                                    <td align="right">
                                                        @item.Volume
                                                    </td>
                                                    <td align="right">
                                                        @item.TotalFee.ToCustomNumberFormat()
                                                    </td>
                                                    <td align="right">
                                                        @item.WoodenPackagingFee.ToCustomNumberFormat()
                                                    </td>

                                                    <td align="right">
                                                        @item.ShockproofFee.ToCustomNumberFormat()
                                                    </td>
                                                    <td align="right">
                                                        @item.DomesticShippingFee.ToCustomNumberFormat()
                                                    </td>
                                                    <td align="right">
                                                        @item.InsuranceFee.ToCustomNumberFormat()
                                                    </td>
                                                    <td align="right">
                                                        @item.TotalPrice.ToCustomNumberFormat()
                                                    </td>

                                                    <td align="left">
                                                        @{
                                                            // Ngày tạo
                                                            var creationTime = item.CreationTime != null ?
                                            item.CreationTime.ToString("dd/MM/yyyy HH:mm") : "-";
                                                            // Ngày xuất kho TQ
                                                            var exportDate = item.ExportDate != null ?
                                            item.ExportDate?.ToString("dd/MM/yyyy HH:mm") : "-";
                                                            // Ngày nhập kho VN
                                                            var importDate = item.ImportDate != null ?
                                            item.ImportDate?.ToString("dd/MM/yyyy HH:mm") : "-";
                                                        }

                                                        <div>
                                                            <strong>@L("CreationTime"):</strong> @creationTime
                                                        </div>
                                                        <div>
                                                            <strong>@L("ExportDateCN"):</strong> @exportDate
                                                        </div>
                                                        <div>
                                                            <strong>@L("ImportDateVN"):</strong> @importDate
                                                        </div>
                                                    </td>
                                                
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>

                        </div>
                        <div class="card-body" style="padding-top: 0px;">
                            <h4><strong> THÔNG TIN ĐƠN HÀNG</strong></h4>
                            <div class="row">
                                <div class="col-4">
                                    <span>Người nhận</span>
                                    <span class="d-block"><strong>@Model.Dto.CustomerName</strong></span>
                                    <span>Kho gửi</span>
                                    <span class="d-block"><strong>@Model.Dto.CNWarehouseName</strong></span>
                                    <span>Kho nhận</span>
                                    <span class="d-block"><strong>@Model.Dto.VNWarehouseName</strong></span>
                                    <span>@L("ShippingLine")</span>
                                    <span class="d-block"><strong>@Model.Dto.ShippingLine</strong></span>
                                </div>
                                <div class="col-8">
                                    <div class="card-body">
                                        <h5>PHÍ DỊCH VỤ</h5>
                                        <table style="width:100%;" class="">
                                            <tr>
                                                <td>Phí bảo hiểm</td>
                                                <td class="text-right">(@(Model.Dto.InsuranceValue.HasValue ?
                                                                                                                                                Model.Dto.InsuranceValue : 0)%) -
                                                    @Model.Dto.Insurance.ToCurrencyFormat()</td>
                                                </tr>
                                                <tr>
                                                    <td>Phí đóng gỗ</td>
                                                    <td class="text-right">@Model.Dto.WoodenPackagingFee.ToCurrencyFormat()</td>
                                                   
                                                </tr>
                                                <tr>
                                                    <td>Phí quấn bọt khí</td>
                                                    <td class="text-right">@Model.Dto.ShockproofFee.ToCurrencyFormat() </td>
                                                     
                                                </tr>
                                                <tr>
                                                    <td>Ship nội địa</td>
                                                    <td class="text-right">@Model.Dto.DomesticShippingFeeRMB (RMB)
                                                        @Model.Dto.DomesticShippingFee.ToCurrencyFormat() </td>
                                                    </tr>
                                                    <tr>
                                                        <td>Phí bao bì</td>
                                                        <td class="text-right">(@Model.Dto.WeightCover kg)
                                                            @Model.Dto.WeightCoverFee.ToCurrencyFormat() </td>
                                                           
                                                        </tr>
                                                    </table>
                                                </div>
                                            </div>
                                 
                                        </div>
                                    </div>
                                     
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
   
            }

 