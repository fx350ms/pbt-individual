@using Pbt.Individual.ApplicationUtils
@using Pbt.Individual.Web.Models.DeliveryRequests

@model CreateUpdateDeliveryRequestModel

@{
    ViewBag.Title = L("CreateDeliveryRequest");
}

@section scripts
{
     <script src="~/view-resources/Views/DeliveryRequests/Create.js" asp-append-version="true"></script>
}

@section styles {
    <style>
      .weight-cover-row{
        background-color: #FFE5B4 !important;
      }
      .section-title {
        font-weight: bold;
        color: #495057;
      }
      .customer-title {
        margin-bottom: 20px;
      }
      .dt-buttons{
        display: none;
      }
      .validation-error {
        margin-bottom: 10px;
        padding: 2px;
      }
      .table.border-danger {
        border-color: #dc3545;
      }
    </style>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1><i class="fas fa-plus-circle text-primary"></i> @L("CreateDeliveryRequest")</h1>
            </div>
            <div class="col-sm-6 text-right">
                <i class="fas fa-user"></i> @Model.CustomerName
            </div>
        </div>
    </div>
</section>
<section class="content">
    <div class="container-fluid">
        <form id="form-dr" onsubmit="return false;">
            <div class="row">
                <div class="col-6">
                    <div class="card">
                        <div class="card-body text-sm">
                            <div class="custom-container">
                                <div class="row">
                                    <div class="col-6">
                                        <div class="form-group">
                                            <label class="section-title"><i class="fas fa-warehouse"></i> @L("Warehouse")</label>
                                            <select class="form-control select2" id="select-warehouse" name="WarehouseId" disabled="disabled">
                                                @if (Model.Warehouses != null && Model.Warehouses.Any())
                                                {
                                                    <option value="-1" selected>Chọn kho</option>
                                                    foreach (var warehouse in Model.Warehouses)
                                                    {
                                                        <option value="@warehouse.Id" data-name="@warehouse.Name">
                                                            @warehouse.Name
                                                        </option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr>
                            <h6 class="customer-title"><i class="fas fa-boxes"></i> @L("BagAndPackageList")</h6>
                            <p class="text-muted small" style="margin-bottom: 0px;">
                                <i class="fas fa-info-circle"></i> 
                                Nhấn nút <strong>"Chọn"</strong> để thêm bao/kiện vào yêu cầu giao, 
                                hoặc nhấn <strong>"Xem kiện"</strong> để xem chi tiết kiện hàng
                            </p>
                            <div class="table-responsive">
                                <table id="bag-package-listTable" class="table table-striped table-bordered table-sm table-hover">
                                    <thead>
                                        <tr>
                                            <th>@L("BagCode")</th>
                                            <th>@L("PackageCode")</th>
                                            <th>@L("TrackingNumber")</th>
                                            <th>@L("Weight")</th>
                                            <th>@L("EntryDate")</th>
                                            <th></th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="7"></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="col-6">
                    <div class="customer-data card">
                        <div class="card-header text-sm">
                            <h4><i class="fas fa-list-check"></i> Yêu cầu giao <b id="deliveryRequestNumber" class="text-danger"></b></h4>
                        </div>
                        <div class="card-body text-sm">
                            <div class="row">
                                <div class="col-12">
                                    <input type="hidden" name="DeliveryRequestId" id="hiddenDeliveryRequestId" />
                                    <h6 class="customer-title"><i class="fas fa-check-circle"></i> Danh sách đã chọn</h6>
                                    <p class="text-muted small" style="margin-bottom: 0px;">
                                        <i class="fas fa-info-circle"></i>
                                        Nhấn nút <strong>"Bỏ chọn"</strong> để loại bỏ bao/kiện, 
                                        hoặc nhấn <strong>"Xem kiện"</strong> để xem chi tiết kiện hàng
                                    </p>
                                    <div class="table-responsive">
                                        <table id="deliveryRequestItemTable"
                                               class="table table-striped table-bordered table-sm table-hover">
                                            <thead>
                                                <tr>
                                                    <th></th>
                                                    <th>@L("BagCode")</th>
                                                    <th>@L("PackageCode")</th>
                                                    <th>@L("TrackingNumber")</th>
                                                    <th>@L("Weight")</th>
                                                    <th>@L("TotalPackage")</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            </tbody>
                                            <tfoot>
                                                <tr>
                                                    <td colspan="7"></td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>

                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group col-md-12">
                                    <label for="note"><i class="fas fa-sticky-note"></i> @L("Note")</label>
                                    <textarea class="form-control" id="txtNote" name="Note" rows="5"
                                              placeholder="@L(name: "EnterNote")"></textarea>
                                </div>
                            </div>
                            <div class="form-row">

                                <div class="col-md-9">
                                    <label><i class="fas fa-map-marker-alt"></i> <strong>@L("Address")</strong></label>
                                    <textarea class="form-control" id="txtAddress" name="Address" rows="2"
                                              placeholder="@L("EnterAddress")"></textarea>
                                </div>
                                <div class="col-md-3">
                                    <label><strong>@L("ShippingMethod") </strong></label>
                                    <select class="form-control" name="ShippingMethod" id="ShippingMethod">
                                        <option value="@((int)ShippingMethod.Delivery)">@ShippingMethod.Delivery.GetDescription()</option>
                                        <option value="@((int)ShippingMethod.Warehouse)">@ShippingMethod.Warehouse.GetDescription()</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-row " style="margin-top:10px;">
                                <div class="col-md-12 text-right">
                                    <button id="btn-submit-dr" class="btn btn-primary btn-submit d-none"
                                            type="button">
                                        @L("SubmitRequest")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

