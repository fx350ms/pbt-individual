@using Pbt.Individual.Web.Startup
@{
    ViewBag.Title = L("Pages_DeliveryRequests");
 
}
@section scripts
{
   
    <environment names="Development">
        <script src="~/view-resources/Views/DeliveryRequests/Index.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/DeliveryRequests/Index.min.js" asp-append-version="true"></script>
    </environment>

}
@section styles
{
    <style>
        hr {
            margin-top: 0px;
            margin-bottom: 0px;
        }
    </style>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>@L("Pages_DeliveryRequests")</h1>
            </div>
            <div class="col-sm-6 text-right">
               
            </div>
        </div>
    </div>

</section>
<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-8">
                <div class="card">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-md-12">
                                @await Html.PartialAsync("~/Views/DeliveryRequests/Index.AdvancedSearch.cshtml")
                            </div>
                        </div>
                    </div>
                    <div class="card-body custom-card-body">
                        <div class="table-responsive">
                            <table id="DeliveryRequestsTable" class="table table-striped table-bordered table-parent">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>@L("RequestNumber")</th>
                                        <th>@L("Status")</th>
                                        <th>@L("Warehouse")</th>
                                        <th>@L("TotalItems")</th>
                                        <th>@L("TimeLine")</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-4">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">HÀNG ĐÃ VỀ KHO</h3>
                    </div>
                    <div class="card-body">
                       <table id="PendingTable" class="table table-striped table-bordered table-parent">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>#</th>
                                        <th>@L("Item")</th>
                                        <th>@L("Waybill")</th>
                                        <th>@L("Warehouse")</th>
                                        <th>@L("TotalItems")</th>
                                        <th>@L("TotalWeight")</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                    </div>

                    <div class="card-footer">
                        <!-- Footer content (if needed) -->
                        <button class="btn btn-primary btn-block" disabled  id="btnCreateDeliveryRequest">@L("CreateNewDeliveryRequest")</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

 