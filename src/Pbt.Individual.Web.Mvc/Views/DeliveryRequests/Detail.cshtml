@using Pbt.Individual.ApplicationUtils
@using Pbt.Individual.Web.Models.DeliveryRequests

@model DetailDeliveryRequestModel

@{
    ViewBag.Title = L("DetailDeliveryRequest");
}

@section scripts
{
      <script src="~/view-resources/Views/DeliveryRequests/Detail.js" asp-append-version="true"></script>
}

@section styles {
    <style>
      .weight-cover-row{
        background-color: #FFE5B4 !important;
      }
      .section-title {
        font-weight: bold;
        color: #495057;
      }
      .customer-title {
        margin-bottom: 20px;
      }
      .dt-buttons{
        display: none;
      }
      .validation-error {
        margin-bottom: 10px;
        padding: 2px;
      }
      .table.border-danger {
        border-color: #dc3545;
      }
    </style>
}
<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1><i class="fas fa-plus-circle text-primary"></i> @L("CreateDeliveryRequest")</h1>
            </div>
        </div>
    </div>
</section>
<section class="content">
    <div class="container-fluid">
        <form id="form-dr" onsubmit="return false;">
            <div class="row">
                <div class="col-12">
                    <div class="customer-data card">
                        <div class="card-header text-sm">
                            <h4><i class="fas fa-list-check"></i> Yêu cầu giao <b id="deliveryRequestNumber" class="text-danger">@Model.deliveryRequestDto.RequestCode</b></h4>
                        </div>
                        <div class="card-body text-sm">
                            <div class="row">
                                <div class="col-12">
                                    <input type="hidden" name="DeliveryRequestId" id="hiddenDeliveryRequestId" value="@Model.DeliveryRequestId" />
                                    <h6 class="customer-title"><i class="fas fa-check-circle"></i> Danh sách bao / kiện</h6>
                                    <div class="table-responsive">
                                        <table id="deliveryRequestItemTable"
                                               class="table table-striped table-bordered table-sm table-hover">
                                            <thead>
                                                <tr>
                                                    <th style="text-align: center;">STT</th>
                                                    <th>@L("BagCode")</th>
                                                    <th>@L("PackageCode")</th>
                                                    <th>@L("TrackingNumber")</th>
                                                    <th>@L("Weight")</th>
                                                    <th>@L("TotalPackage")</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            </tbody>
                                            <tfoot>
                                                <tr>
                                                    <td colspan="7"></td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group col-md-12">
                                    <label for="note"><i class="fas fa-sticky-note"></i> @L("Note")</label>
                                    <p class="form-control-plaintext" style="border: 1px solid #ced4da; padding: 0.375rem 0.75rem; border-radius: 0.25rem; background-color: #f8f9fa;">@Model.deliveryRequestDto.Note</p>
                                </div>
                            </div>
                            <div class="form-row">

                                <div class="col-md-9">
                                    <label><i class="fas fa-map-marker-alt"></i> <strong>@L("Address")</strong></label>
                                    <p class="form-control-plaintext" style="border: 1px solid #ced4da; padding: 0.375rem 0.75rem; border-radius: 0.25rem; background-color: #f8f9fa;">@Model.deliveryRequestDto.Address</p>
                                </div>
                                <div class="col-md-3">
                                    <label><strong>@L("ShippingMethod") </strong></label>
                                    <p class="form-control-plaintext" style="border: 1px solid #ced4da; padding: 0.375rem 0.75rem; border-radius: 0.25rem; background-color: #f8f9fa;">@Model.deliveryRequestDto.ShippingMethodEnum.GetDescription()</p>
                                </div>
                            </div>
                            <div class="form-row " style="margin-top:10px;">
                                <div class="col-md-12 text-right">
                                    <button id="btn-submit-dr" class="btn btn-primary btn-submit d-none"
                                            type="button">
                                        @L("SubmitRequest")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

