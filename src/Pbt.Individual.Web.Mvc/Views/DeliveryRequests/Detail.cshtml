@using Pbt.Individual.ApplicationUtils
@using Pbt.Individual.Web.Models.DeliveryRequests
@using Pbt.Individual.Core

@model DetailDeliveryRequestModel

@{
    ViewBag.Title = L("DetailDeliveryRequest");
}

@section scripts
{
      <script src="~/view-resources/Views/DeliveryRequests/Detail.js" asp-append-version="true"></script>
}

@section styles {
    <style>
      .weight-cover-row{
        background-color: #e9ecef !important;
        opacity: 0.6 !important;
        color: #6c757d !important;
        filter: grayscale(100%) !important;
      }
      .section-title {
        font-weight: bold;
        color: #495057;
      }
      .customer-title {
        margin-bottom: 20px;
      }
      .dt-buttons{
        display: none;
      }
      .validation-error {
        margin-bottom: 10px;
        padding: 2px;
      }
      .table.border-danger {
        border-color: #dc3545;
      }

      /* Table styling according to project specifications */

/* Header styling for all tables */
.table th {
  background-color: #e9ecef;
}

/* Hover effect for tables with table-hover class */
.table-hover tbody tr:hover {
  background-color: #d1ecff;
}

/* Specific child table styling */
.table-child {
  background-color: #f8f9fa;
  box-shadow: 0 2px 4px rgba(0,0,0,.1);
  border-collapse: separate;
  border-spacing: 0;
  overflow: hidden;
}

.table-child th {
  background-color: #e9ecef;
  font-weight: 600;
}

.table-child td, .table-child th {
  border: 1px solid #dee2e6;
  padding: 6px !important;
}

/* Hover effect for child tables */
.table-child tbody tr:hover {
  background-color: #d1ecff;
}
</style>
}
<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1><i class="fas fa-plus-circle text-primary"></i> @L("DetailDeliveryRequest")</h1>
            </div>
        </div>
    </div>
</section>
<section class="content">
    <div class="container-fluid">
        <form id="form-dr" onsubmit="return false;">
            <div class="row">
                <div class="col-12">
                    <div class="customer-data card">
                        <div class="card-header text-sm">
                            <h4><i class="fas fa-list-check"></i> Yêu cầu giao <b id="deliveryRequestNumber" class="text-danger">@Model.deliveryRequestDto.RequestCode</b></h4>
                        </div>
                        <div class="card-body text-sm">
                            <div class="row">
                                <div class="col-12">
                                    <input type="hidden" name="DeliveryRequestId" id="hiddenDeliveryRequestId" value="@Model.DeliveryRequestId" />
                                    
                                    <div class="form-row mb-3">
                                        <div class="col-md-3">
                                            <label><i class="fas fa-info-circle"></i> <strong>@L("Status")</strong></label>
                                            @{
                                                string statusText = Model.deliveryRequestDto.Status switch
                                                {
                                                    1 => "Tạo mới",
                                                    2 => "Đã gửi",
                                                    3 => "Đang xử lý",
                                                    4 => "Hoàn thành",
                                                    5 => "Hủy",
                                                    _ => "Không xác định"
                                                };
                                                
                                                string statusClass = Model.deliveryRequestDto.Status switch
                                                {
                                                    1 => "badge-secondary", // Tạo mới
                                                    2 => "badge-info",      // Đã gửi
                                                    3 => "badge-warning",   // Đang xử lý
                                                    4 => "badge-success",   // Hoàn thành
                                                    5 => "badge-danger",    // Hủy
                                                    _ => "badge-dark"       // Không xác định
                                                };
                                            }
                                            <span class="badge @statusClass">@statusText</span>
                                        </div>
                                    </div>
                                    
                                    <h6 class="customer-title"><i class="fas fa-check-circle"></i> Danh sách bao / kiện</h6>
                                    <div class="table-responsive">
                                        <table id="deliveryRequestItemTable"
                                               class="table table-bordered table-sm table-hover">
                                            <thead>
                                                <tr>
                                                    <th style="text-align: center;">STT</th>
                                                    <th>@L("BagCode")</th>
                                                    <th>@L("PackageCode")</th>
                                                    <th>@L("TrackingNumber")</th>
                                                    <th>@L("Weight")</th>
                                                    <th>@L("TotalPackage")</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            </tbody>
                                            <tfoot>
                                                <tr>
                                                    <td colspan="7"></td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group col-md-12">
                                    <label for="note"><i class="fas fa-sticky-note"></i> @L("Note")</label>
                                    <p class="text-muted">@Model.deliveryRequestDto.Note</p>
                                </div>
                            </div>
                            <div class="form-row">

                                <div class="col-md-9">
                                    <label><i class="fas fa-map-marker-alt"></i> <strong>@L("Address")</strong></label>
                                    <p class="text-muted">@Model.deliveryRequestDto.Address</p>
                                </div>
                                <div class="col-md-3">
                                    <label><strong>@L("ShippingMethod") </strong></label>
                                    <p class="text-muted">@Model.deliveryRequestDto.ShippingMethodEnum.GetDescription()</p>
                                </div>
                            </div>
                            <div class="form-row " style="margin-top:10px;">
                                <div class="col-md-12 text-right">
                                    <button id="btn-submit-dr" class="btn btn-primary btn-submit d-none"
                                            type="button">
                                        @L("SubmitRequest")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>